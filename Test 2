<!DOCTYPE html>

<html lang="fr" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8" />
    <title>Stream-In</title>
    <style>

        body {
            margin: 0;
            background: #0b0b0b;
            font-family: Arial, Helvetica, sans-serif;
            color: white;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background: #111;
            border-bottom: 1px solid #222;
        }

        .logo {
            color: #e50914;
            font-size: 38px;
            font-weight: bold;
            letter-spacing: 2px;
        }

        .menu {
            color: #888;
            font-size: 14px;
        }

        .hero {
            height: 45vh;
            background: linear-gradient(to top, rgba(11,11,11,1), rgba(11,11,11,0.4)), url('https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?q=80&w=2070&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: end;
            padding: 60px;
        }

        .hero-content {
            max-width: 600px;
        }

        .hero h1 {
            font-size: 58px;
            margin: 0;
        }

        .hero p {
            color: #ddd;
            line-height: 1.6;
        }

        .section {
            padding: 40px 50px;
        }

            .section h2 {
                margin-bottom: 25px;
                font-size: 28px;
            }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(220px,1fr));
            gap: 25px;
        }

        .card {
            background: #181818;
            border-radius: 8px;
            overflow: hidden;
            transition: 0.3s;
            cursor: pointer;
        }

            .card:hover {
                transform: scale(1.04);
            }

            .card img {
                width: 100%;
                height: 340px;
                object-fit: cover;
            }

        .card-content {
            padding: 15px;
        }

        .card h3 {
            margin: 0 0 10px;
            font-size: 20px;
        }

        .card p {
            margin: 0;
            color: #999;
            font-size: 14px;
            line-height: 1.5;
        }

        footer {
            padding: 30px;
            text-align: center;
            color: #666;
            border-top: 1px solid #222;
            margin-top: 40px;
        }
    </style>
</head>

<body>

    <header>
        <div class="logo">STREAM-IN</div>
        <div class="menu">Films • Séries • Nouveautés • Fuites Festival</div>
    </header>

    <section class="hero">
        <div class="hero-content">
            <h1>Lecture de Johns,<br>selon Tommy</h1>

            <p>
                Le film d’ouverture du Festival de Cannes a fuité.
                La version complète actuellement sur Stream-In.
            </p>
        </div>
    </section>

    <section class="section">

        <h2>Les meilleurs fuites</h2>

        <div class="grid">

            <!-- FILM 1 -->
            <div class="card">
                <img src="https://i.imgur.com/JA5JLH4.png">
                <div class="card-content">
                    <h3>Lecture de Johns, selon Tommy</h3>
                    <p>Biopic dramatique • Version incomplète</p>
                </div>
            </div>

            <!-- FILM 2 -->
            <div class="card">
                <img src="https://i.imgur.com/u0LLey1.png">
                <div class="card-content">
                    <h3>La Dernière Partition d’Elias Ward</h3>
                    <p>Drame musical • Festival international</p>
                </div>
            </div>

            <!-- FILM 3 -->
            <div class="card">
                <img src="https://i.imgur.com/lddllSa.png">
                <div class="card-content">
                    <h3>Les Silences de Brighton</h3>
                    <p>Thriller psychologique • Atmosphère côtière</p>
                </div>
            </div>

            <!-- FILM 4 -->
            <div class="card">
                <img src="https://i.imgur.com/APwmLnq.png">
                <div class="card-content">
                    <h3>Les Lettres d’Avant Minuit</h3>
                    <p>Drame romantique • Correspondances oubliées</p>
                </div>
            </div>

            <!-- FILM 5 -->
            <div class="card">
                <img src="https://i.imgur.com/Gz3PKUA.png">
                <div class="card-content">
                    <h3>Le Bruit des Couloirs Vides</h3>
                    <p>Thriller dramatique • Huis clos psychologique</p>
                </div>
            </div>
            <!-- FILM 6-->
            <div class="card">
                <img src="https://i.imgur.com/p9ym4a3.png">
                <div class="card-content">
                    <h3>Avant le Générique</h3>
                    <p>Drame cinéma • Festival de Venise</p>
                </div>
            </div>

            <!-- FILM 7-->
            <div class="card">
                <img src="https://i.imgur.com/qy7tK2k.png">
                <div class="card-content">
                    <h3>L’Hiver selon Gabriel</h3>
                    <p>Drame intimiste • Sélection officielle</p>
                </div>
            </div>

            <!-- FILM 8-->
            <div class="card">
                <img src="https://i.imgur.com/Pvy279s.png">
                <div class="card-content">
                    <h3>La Mémoire des Harmonies</h3>
                    <p>Film musical • Prix du Jury</p>
                </div>
            </div>

            

</section>

    <footer>
        Stream-In • Hébergement anonyme • Aucun contenu stocké sur nos serveurs
    </footer>

</body>
</html>
